# TSiSIP Runtime Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env files with real secrets.

# OpenSIPS listener and advertised public IP
OPENSIPS_LISTEN_IP=0.0.0.0
HOST_PUBLIC_IP=203.0.113.10

# RTPengine networking
RTPENGINE_PRIVATE_IP=10.0.0.2
RTPENGINE_INTERNAL_IP=10.0.0.2

# OpenSIPS → RTPengine control
RTPENGINE_HOST=rtpengine

# Topology hiding secret (32+ characters recommended)
TOPOLOGY_SECRET=change-me-to-a-long-random-string-32-chars

# Database connection (PostgreSQL)
DB_HOST=postgres
DB_NAME=opensips
DB_USER=opensips

# Database credentials are injected via Docker secrets.
# The DB_PASSWORD file should be placed in secrets/db_password
# The AUTH_SECRET file should be placed in secrets/auth_secret (32 chars)
# The TOPOLOGY_SECRET file should be placed in secrets/topology_secret
