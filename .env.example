# TSiSIP Runtime Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env files with real secrets.

# Image tag for all tsisip/* services
# DEVELOPMENT: use a non-floating tag (e.g., git short-sha or v0.0.0-dev)
# PRODUCTION:  always pin to a specific version (e.g., v0.6.0-stabilized)
# WARNING: Never use 'latest' in production. Pin to a specific version or git SHA.
TSISIP_IMAGE_TAG=v0.0.0-dev

# OpenSIPS listener and advertised public IP
OPENSIPS_LISTEN_IP=0.0.0.0
HOST_PUBLIC_IP=203.0.113.10

# WebSocket ports (host side). Change if 8080/4443 are in use by other services.
OPENSIPS_WS_PORT=8081
OPENSIPS_WSS_PORT=4443

# RTPengine networking
# RTPENGINE_PRIVATE_IP is auto-detected by entrypoint; leave unset for DHCP
# RTPENGINE_PRIVATE_IP=10.0.0.2
# RTPENGINE_INTERNAL_IP is auto-detected by entrypoint; leave unset for DHCP
# RTPENGINE_INTERNAL_IP=10.0.0.2

# OpenSIPS → RTPengine control
RTPENGINE_HOST=rtpengine

# Topology hiding secret (32+ characters recommended)
TOPOLOGY_SECRET=change-me-to-a-long-random-string-32-chars

# Database connection (PostgreSQL)
DB_HOST=postgres
DB_NAME=opensips
DB_USER=opensips

# VPS Target (TSiAPP) — canonical parameters
VPS_TSiAPP_HOSTNAME=TSiAPP
VPS_TSiAPP_IP_PUBLIC=179.190.15.116
VPS_TSiAPP_IP_TAILSCALE=100.111.74.69
VPS_TSiAPP_PORT=22
VPS_TSiAPP_USER=tsi
VPS_TSiAPP_KEY=TSiHomeLab

# TLS / ACME certificate rotation (Feature 014-A)
TLS_DOMAIN=tsiapp.io
ACME_EMAIL=admin@tsiapp.io
ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory
CERTBOT_STAGING=0
TAILSCALE_CERT_ENABLED=0
TS_HOSTNAME=tsisip

# OCP audit log retention (Feature 014-B Wave 5)
OCP_AUDIT_RETENTION_DAYS=90

# LGPD compliance retention (Feature 019)
LGPD_RETENTION_DAYS=365
LGPD_ANONYMIZE_AFTER_DAYS=365

# Admin API rate limits (requests per minute)
# These limits protect the subscriber management endpoints from abuse.
SUBSCRIBER_CREATE_RATE_LIMIT=10
SUBSCRIBER_UPDATE_RATE_LIMIT=30
SUBSCRIBER_DELETE_RATE_LIMIT=10

# Database credentials are injected via Docker secrets.
# The DB_PASSWORD file should be placed in secrets/db_password
# The AUTH_SECRET file should be placed in secrets/auth_secret (32 chars)
# The TOPOLOGY_SECRET file should be placed in secrets/topology_secret
# The TRUNK_CRED_KEY file should be placed in secrets/trunk_cred_key
# Generate with: openssl rand -base64 32

# Alertmanager notification configuration
ALERTMANAGER_SMTP_FROM=alerts@tsiapp.io
ALERTMANAGER_SMTP_HOST=smtp.tsiapp.io:587
ALERTMANAGER_WEBHOOK_URL=https://hooks.tsiapp.io/alertmanager

# Grafana public root URL (used for alert links and redirects)
GRAFANA_ROOT_URL=https://grafana.tsiapp.io

# Rclone backup target configuration (S3-compatible)
RCLONE_REMOTE_NAME=tsisip-backup
RCLONE_REMOTE_PATH=tsisip-backups
RCLONE_S3_ENDPOINT=https://s3.tsiapp.io
RCLONE_S3_PROVIDER=AWS
RCLONE_S3_REGION=us-east-1
RCLONE_BW_LIMIT=10M

# NOTE: HOST_PUBLIC_IP, OPENSIPS_LISTEN_IP, RTPENGINE_INTERNAL_IP, RTPENGINE_PRIVATE_IP,
# ACME_EMAIL, and TLS_DOMAIN are defined above. Do not duplicate.

# PostgreSQL connection defaults (used by backup healthcheck and scripts)
PGHOST=postgres
PGPORT=5432
PGUSER=opensips

# RTPengine Network Configuration
# RTPENGINE_INTERNAL_IP: IP for RTPengine control socket (sip_internal network)
# RTPENGINE_PRIVATE_IP: IP for RTPengine media interface (sip_internal network)
RTPENGINE_INTERNAL_IP=rtpengine
RTPENGINE_PRIVATE_IP=rtpengine
