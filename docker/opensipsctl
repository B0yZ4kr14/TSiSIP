#!/bin/bash
# opensipsctl compatibility wrapper for OpenSIPS 3.6 mi_http
# Translates: opensipsctl fifo <cmd> [args...]
# Into:       curl -fsSL http://localhost:8888/mi/<cmd>[/<arg1>...]

set -e

MI_URL="http://localhost:8888/mi"

if [ "$1" != "fifo" ]; then
    echo "Usage: opensipsctl fifo <command> [args...]" >&2
    exit 1
fi

shift  # remove 'fifo'

if [ $# -eq 0 ]; then
    echo "Missing command" >&2
    exit 1
fi

# Build URL path from command and arguments
url_path=""
for arg in "$@"; do
    # Minimal URL-encoding for common special characters
    encoded_arg=$(printf '%s' "$arg" | sed 's/ /%20/g; s/!/%21/g; s/#/%23/g; s/\$/%24/g; s/&/%26/g; s/(/%28/g; s/)/%29/g; s/\*/%2A/g; s/+/%2B/g; s/,/%2C/g; s/\//%2F/g; s/:/%3A/g; s/;/%3B/g; s/=/%3D/g; s/?/%3F/g; s/\[/%5B/g; s/\]/%5D/g')
    if [ -z "$url_path" ]; then
        url_path="$encoded_arg"
    else
        url_path="$url_path/$encoded_arg"
    fi
done

# Use curl to call mi_http; -f ensures non-zero exit on HTTP errors
curl -fsSL --connect-timeout 3 --max-time 10 "${MI_URL}/${url_path}"
