# TSiSIP runtime secrets
secrets/

# Local environment files
.env
.env.*
!.env.example

# Local runtime/log artifacts
*.log
*.pid

# Universal
.DS_Store
Thumbs.db
*.tmp
*.swp
.vscode/
.idea/

# Node.js / build artifacts
node_modules/
build/node_modules/
dist/
build/dist/

# PHP
vendor/
*.cache

# Local SSH config (may contain real paths after template instantiation)
.ssh/

# Sisyphus execution artifacts
.sisyphus/evidence/

# Generated TSiSIP assets (build output)
web/tsisip/assets/
web/tsisip/css/*.css
!web/tsisip/css/.gitkeep
web/tsisip/js/*.js
!web/tsisip/js/.gitkeep
web/tsisip/asset-manifest.json
*.mo

# Test artifacts
coverage/
tests/visual-regression/
tests/accessibility/
tests/performance/results/

# Python cache
__pycache__/
*.pyc
ca-offline/
.env.local
.env.production

# Spec Kit Memory Hub
.spec-kit-memory/
docs/memory/INDEX.md.lock
.gitnexus/meta.json

# Speckit extension generated files (orchestration state, not source)
.agents/skills/
.claude/skills/speckit-*/
.github/agents/speckit.*.agent.md
.opencode/commands/speckit.*.md
.github/prompts/speckit.*.prompt.md
.kimi/skills/speckit-*/
# Squad: ignore runtime state (logs, inbox, sessions, casting, templates)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/casting/
.squad/identity/
.squad/templates/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Agent framework runtime artifacts (not project source)
.agent/
.copilot/

deploy/nginx/ssl/*.key
deploy/nginx/ssl/*-selfsigned.*
evidence/
.docguard/
reports/benchmarks/
